# Copy this file to server/.env and fill in values. Do NOT commit your real API key.
# For Google Gemini/Vertex AI (recommended):
GEMINI_PROVIDER=google
# Model can be text-bison-001 or chat-bison-001 depending on availability
GEMINI_MODEL=text-bison-001
GEMINI_API_KEY=REPLACE_WITH_GOOGLE_API_KEY
PORT=5174

# For a generic provider (alternative):
# GEMINI_PROVIDER=generic
# GEMINI_URL=https://your-gemini-endpoint.example/v1/generate
# GEMINI_API_KEY=sk-REPLACE_WITH_YOUR_KEY
